{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "paths": {
      "~/*": ["./src/*"],
      "~components/*": ["./src/components/*"],
      "~layouts/*": ["./src/layouts/*"],
      "~utils/*": ["./src/utils/*"],
      "~data/*": ["./src/data/*"],
      "~styles/*": ["./src/styles/*"],
      "~config/*": ["./src/config/*"]
    }
  },
  "exclude": [
    "coverage/**/*",
    "dist/**/*",
    "node_modules/**/*"
  ]
}