---
import wordnikLogo from '../assets/wordnik-gearheart.png';
const currentYear = new Date().getFullYear();
const attributionUrl = 'https://github.com/seriouslysean';
---

<footer class="footer" role="contentinfo">
    <p class="footer__text">
        <a href="/words" aria-label="View all words">All Words</a>
        <span class="footer__separator">&middot;</span>
        <a href="/stats" aria-label="View word statistics">Stats</a>
        <span class="footer__separator">&middot;</span>
        <a href={attributionUrl} target="_blank" rel="noopener noreferrer" aria-label="View Sean Kennedy's GitHub profile (opens in new tab)">Made with &lt;3, {currentYear}</a>
        <span class="footer__separator">|</span>
        <a href="https://www.wordnik.com" target="_blank" rel="noopener noreferrer" class="footer__wordnik" title="Powered by Wordnik" aria-label="Powered by Wordnik (opens in new tab)">
            <img src={wordnikLogo.src} alt="Wordnik" width="16" height="16" />
        </a>
    </p>
</footer>

<style>
    .footer {
        margin-top: auto;
        padding: 1rem;
        text-align: center;
    }

    .footer__text {
        margin: 0;
        font-size: 0.875rem;
        color: var(--color-text-lighter);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.25rem;
        text-transform: lowercase;
    }

    .footer__text a {
        color: inherit;
    }

    .footer__separator {
        margin: 0 0.5rem;
        opacity: 0.5;
    }

    .footer__wordnik {
        display: flex;
        align-items: center;
        opacity: 0.5;
        transition: opacity 0.2s ease;
    }

    .footer__wordnik:hover {
        opacity: 1;
    }

    .footer__wordnik img {
        height: 16px;
        width: auto;
        filter: sepia(0.4) hue-rotate(350deg) saturate(1.5);
    }
</style>
