{
  "name": "wordbug",
  "type": "module",
  "version": "2.3.5",
  "description": "An (occasional) word of the day that my son thinks is cool",
  "keywords": [
    "word-of-the-day",
    "vocabulary",
    "learning",
    "astro",
    "static-site"
  ],
  "author": "Sean Kennedy <sean@codeserious.com>",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "tool:add-word": "node tools/add-word.js",
    "tool:generate-word-data": "node tools/generate-word-data.js",
    "tool:generate-word-images": "node tools/generate-word-images.js",
    "tool:generate-word-image": "node tools/generate-word-image.js",
    "tool:generate-generic-images": "node tools/generate-generic-images.js",
    "tool:generate-page-image": "node tools/generate-page-image.js",
    "tool:generate-all-images": "npm run tool:generate-word-images && npm run tool:generate-generic-images",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "astro check"
  },
  "dependencies": {
    "astro": "^5.10.1",
    "astro-seo-schema": "^5.0.0",
    "entities": "^6.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/sitemap": "^3.4.1",
    "@eslint/js": "^9.29.0",
    "@sentry/astro": "^9.32.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.29.0",
    "eslint-plugin-astro": "^1.3.1",
    "opentype.js": "^1.3.4",
    "sharp": "^0.34.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4"
  }
}
